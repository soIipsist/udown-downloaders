{
  "udown": {
    "downloader_type": "imdb",
    "module": "downloaders.selenium_downloader",
    "downloader_func": "download",
    "downloader_args": "url, browser_options_path=chrome, selenium_options_path=downloader_path, output_directory=output_directory, proxy=proxy"
  },
  "browser_options": {
    "arguments": ["--window-size=1920,1080"],
    "capabilities": {
      "goog:loggingPrefs": {
        "performance": "ALL"
      }
    }
  },
  "events": ["a = network()", "sleep(10)", "screenshot('hello.png')", "save(a)"]
}
