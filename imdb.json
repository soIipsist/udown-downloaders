{
  "udown": {
    "downloader_type": "imdb",
    "module": "downloaders.selenium_downloader",
    "downloader_func": "download",
    "downloader_args": "url, downloader_path, output_directory=output_directory"
  },
  "browser_type": "chrome",
  "browser_options": {
    "experimental_options": {
      "detach": true
    },
    "arguments": [
      "--ignore-certificate-errors",
      "--disable-gpu",
      "--allow-running-insecure-content"
    ],
    "capabilities": {
      "goog:chromeOptions": {
        "perfLoggingPrefs": {
          "enableNetwork": true
        }
      }
    }
  },
  "events": ["extract_structured(//a)", "quit()"]
}
